{
  "name": "otlp-viewer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "generate:types && next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:types": "buf generate buf.build/opentelemetry/opentelemetry --path opentelemetry/proto/logs --path opentelemetry/proto/common --path opentelemetry/proto/resource"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/otlp-transformer": "^0.220.0",
    "@remixicon/react": "^4.9.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "16.2.10",
    "postcss": "^8.5.19",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.71.0",
    "@tanstack/eslint-plugin-query": "^5.101.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "ts-proto": "^2.12.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "@bufbuild/buf@1.71.0": true
  }
}
